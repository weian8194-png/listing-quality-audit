{
  "version": 2,
  "builds": [
    {
      "src": "api/amazon.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "amazon-reader.js"
        ],
        "maxDuration": 20
      }
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/amazon",
      "dest": "/api/amazon.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
